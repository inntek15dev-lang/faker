    "security_hardening": {
      "standard": "IEEE 7000 (Privacy by Design)",
      "auth_policy": "JWT_RS256",
      "encryption_targets": [
        "users.password",
        "users.email",
        "users.rut",
        "users.telefono"
      ],
      "pii_fields": [
        "users.name",
        "users.email",
        "users.rut",
        "users.telefono",
        "users.eecc_nombre",
        "registros.eecc_nombre",
        "registro_actividades.responsable",
        "hallazgos.responsable"
      ],
      "audit_logic": "Global_Event_Sourcing",
      "rbac_policy": {
        "admin": {"modules": "*", "actions": ["read", "write", "excec"]},
        "administrador_contrato": {"modules": ["Admin_Registros", "Admin_MisContratistas", "Admin_SolicitudesReapertura", "Contratista_Usuarios", "Admin_Compromisos", "Registros_Exportar", "Dashboard"], "actions": ["read", "excec"]},
        "contratista_admin": {"modules": ["Contratista_Dashboard", "Contratista_Historial", "Contratista_SolicitudesReapertura", "Contratista_Evidencias", "Contratista_Usuarios", "Contratista_Compromisos", "Registros_Exportar"], "privileges": [], "actions": ["read", "write", "excec"]},
        "contratista_user": {"modules": ["Contratista_Dashboard", "Contratista_Historial", "Contratista_SolicitudesReapertura", "Contratista_Evidencias", "Admin_Compromisos", "Registros_Exportar"], "privileges": [], "actions": ["read", "write", "excec"]}
      }
    }
  }
}
